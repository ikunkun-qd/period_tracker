<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- 禁用云备份以保护用户隐私 -->
    <cloud-backup>
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="file" />
    </cloud-backup>
    
    <!-- 禁用设备间传输 -->
    <device-transfer>
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
